# EMA environment variables
#
# Usage:
#   1. Copy this file to `.env`.
#   2. Fill the real values below.
#   3. In setup or dashboard settings, enter the environment variable name
#      (for example `GEMINI_API_KEY`) rather than the secret value itself.
#
# Development startup:
#   pnpm webui -- --dev
#
# Production startup:
#   pnpm webui -- --prod --mongo "mongodb://user:password@host:27017/ema?authSource=admin"

# Google Gemini API key mode
# In setup/dashboard:
#   ApiKey = GEMINI_API_KEY
GEMINI_API_KEY=

# Google Vertex AI mode
# In setup/dashboard:
#   Project = GOOGLE_CLOUD_PROJECT
#   Region = GOOGLE_CLOUD_LOCATION
#   Credentials = GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# OpenAI or OpenAI-compatible API key mode
# In setup/dashboard:
#   ApiKey = OPENAI_API_KEY
#   Base URL = https://api.openai.com/v1
OPENAI_API_KEY=

# Optional proxy used by outbound provider requests.
HTTPS_PROXY=